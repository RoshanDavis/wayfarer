{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "webdev",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8080"],
      "port": 8080
    },
    {
      "name": "web-release",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8081", "--directory", "build/web"],
      "port": 8081
    }
  ]
}
